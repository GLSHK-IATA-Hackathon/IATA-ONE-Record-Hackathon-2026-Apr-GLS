  //logger configure
  "Logging": {
    "LargeBodySetting": {
      "SizeThreshold": 64, //unit: KB; -1 means never log large body; Size >64 cannot log to ELK
      "Location": "logs\\LogLargeBody"
    },
    "LogLevel": {
      "Microsoft": "None" //turn off logging done by core framework: e.g.: remove logging for 'Microsoft'
    },
    //configure "ApiMiddleware" to auto log a pair of "request" + "response"
    "ApiMiddleware": {
      //LogRequestBodySupportedMethod: Check method that requried to log body
      //if "LogRequestBodySupportedMethod " has been removed, or {"LogRequestBodySupportedMethod ": [] }, by default: "POST", "PUT", "PATCH", "DELETE", "GET" 
      // "LogRequestBodySupportedMethod"=  [""] no body will be recorded
      "LogRequestBodySupportedMethod ": [ "POST", "PUT", "PATCH", "DELETE", "GET" ],
      //ExcludedPath: check Path which is not required to write log
      //  e.g.: "ExcludedPath": ["healthcheck"] -> healthcheck request will not be logged
      //if "ExcludedPath " has been removed, or {"ExcludedPath ": []}, by default: ExcludedPath = "healthcheck", "swagger" 
      // "ExcludedPath"=  [""] ALL request and response will be recorded
      "ExcludedPath": [ "healthcheck", "swagger" ]
    }
  },
  //if "ELK_appName" / "ELK_environment" are not configurated, the "ELK_appName" = [project name]; "ELK_environment" = [ASPNETCORE_ENVIRONMENT];
  //"ELK_appName": "WebAPITemplateConfigure",
