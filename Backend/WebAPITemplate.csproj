    <Description>Update docker file, and nuget package version</Description>
    <FileVersion>2025.09.16.0</FileVersion>
    <AssemblyVersion>8.0.0.1</AssemblyVersion>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="GLSHK.APIClient" Version="6.1.25198" />
    <PackageReference Include="GLSHK.Common" Version="6.1.0.25199" />
    <PackageReference Include="GLSHK.Logging" Version="6.0.23110" />
    <PackageReference Include="GLSHK.Redis" Version="6.0.24151" />
    <PackageReference Include="Microsoft.VisualStudio.Azure.Containers.Tools.Targets" Version="1.22.1" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="9.0.4" />
  </ItemGroup>

  <ItemGroup>
