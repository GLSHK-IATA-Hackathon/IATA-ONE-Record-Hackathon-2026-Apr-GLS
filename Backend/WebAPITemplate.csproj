    <Folder Include="Filter\" />
    <Folder Include="Interface\" />
    <Folder Include="Middlewares\" />
    <Folder Include="Models\Common\" />
    <Folder Include="Models\DB\DataHandler\" />
    <Folder Include="Models\DB\DBObject\" />
    <Folder Include="Models\Enum\" />
    <Folder Include="Resource\" />
    <Folder Include="Response\" />
    <Folder Include="Repositories\" />
    <Folder Include="RestClients\" />
    <Folder Include="Services\" />
    <Folder Include="Swagger\" />
    <Folder Include="View\" />
    <Folder Include="Web References\" />
  </ItemGroup>

  <ItemGroup>
    <None Include="config\DataSource.d0.config" />
    <None Include="config\DataSource.d1.config" />
    <None Include="config\DataSource.d2.config" />
    <None Include="config\DataSource.config" />
    <None Include="config\DataSource.Development.config" />
  </ItemGroup>

  <ItemGroup>
    <Content Update="appsettings.d0.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
    <Content Update="appsettings.d2.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
    <Content Update="appsettings.d1.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
    <Content Update="appsettings.p0-green.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
    <Content Update="appsettings.p0-blue.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
