  "components": {
    "schemas": {
      "CachePerson": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "age": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "ContactInfo": {
        "type": "object",
        "properties": {
          "telNo": {
            "type": "string",
            "nullable": true
          },
          "mobileNo": {
            "type": "string",
            "nullable": true
          },
          "address": {
            "type": "string",
            "nullable": true
          },
          "emergencyPerson": {
            "type": "string",
            "nullable": true
          },
          "additionalEmail": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LogLevel": {
        "enum": [
          1,
          2,
          3,
          4,
          5,
          6
        ],
        "type": "integer",
        "format": "int32"
      },
      "Person": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "age": {
            "type": "integer",
            "format": "int32"
          },
          "contactInfo": {
            "$ref": "#/components/schemas/ContactInfo"
          }
        },
        "additionalProperties": false
      },
      "PersonName": {
        "type": "object",
        "properties": {
          "surname": {
            "type": "string",
            "nullable": true
          },
          "forename": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ReorderLevel": {
        "enum": [
          0,
          5,
          10,
          15,
          20,
          25,
          30
        ],
        "type": "integer",
        "format": "int32"
      },
      "Severity": {
        "enum": [
          0,
          1,
          2
        ],
        "type": "integer",
        "format": "int32"
      },
      "ValidInfoBody": {
        "required": [
          "age",
          "birthday",
          "capitalLetter",
          "name",
          "optionalValue",
          "sellEndDate",
          "testEnum"
        ],
        "type": "object",
        "properties": {
          "optionalValue": {
            "minLength": 1,
            "type": "string"
          },
          "name": {
            "maxLength": 4,
            "minLength": 0,
            "type": "string"
          },
          "age": {
            "maximum": 130,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "sellEndDate": {
            "type": "string",
            "format": "date-time"
          },
          "birthday": {
            "type": "string",
            "format": "date-time"
          },
          "testEnum": {
            "$ref": "#/components/schemas/ReorderLevel"
          },
          "capitalLetter": {
            "maxLength": 5,
            "minLength": 0,
            "pattern": "[A-Z]*",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "ValidInfoResult": {
        "type": "object",
        "properties": {
          "isValid": {
            "type": "boolean"
          },
          "list": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ValidItem"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ValidItem": {
        "type": "object",
        "properties": {
          "field": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          },
          "message": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ValidationFailure": {
        "type": "object",
        "properties": {
          "propertyName": {
            "type": "string",
            "nullable": true
          },
          "errorMessage": {
            "type": "string",
            "nullable": true
          },
          "attemptedValue": {
            "nullable": true
          },
          "customState": {
            "nullable": true
          },
          "severity": {
            "$ref": "#/components/schemas/Severity"
          },
          "errorCode": {
            "type": "string",
            "nullable": true
          },
          "formattedMessagePlaceholderValues": {
            "type": "object",
            "additionalProperties": {
              "nullable": true
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ValidationResult": {
        "type": "object",
        "properties": {
          "isValid": {
            "type": "boolean",
            "readOnly": true
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ValidationFailure"
            },
            "nullable": true
          },
          "ruleSetsExecuted": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
